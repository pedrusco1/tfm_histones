project:
  type: book
  execute-dir: project

book:
  title: "Regresión de Dirichlet con campos epistáticos para el análisis bayesiano de datos composicionales de proteoformas de histona H3 9–17"
  subtitle: "Aplicación a perfiles de modificaciones postraduccionales de H3K9–S10–K14 durante la transición de asincronía a mitosis"
  author: "Pedro Martí Requena"
  date: "2026"
  chapters:
    - index.qmd
    - 10_introduccion_biologica.v4.qmd
    - 20_Metodos_summary.qmd
    - 31_resultados_descri_v1.qmd
    - 32_resultados_bioinfo_v1.qmd
    - 33_resultados_bayesianos.qmd
    - 37_resultados_kappa_comun_dia.qmd
    - 38_resultados_epistasia_descomposicion_varianza_corto_dia.qmd
    - 40_discusion_v2.qmd
    - 50_conclusiones.qmd
    - referencias.qmd

lang: es-ES

bibliography: ../references.bib
csl: ../plos-computational-biology.csl

# Opciones globales
execute: 
  echo: false
  warning: false
  message: false

format:
  pdf:
    titlepage: false
    toc: true
    toc-depth: 2
    toc-title: "Índice de contenidos"
    number-sections: true
    geometry:
      - margin=2.5cm
    mainfont: "Latin Modern Roman"
    monofont: "Latin Modern Mono"
    include-in-header: 
      text: |
        \usepackage{needspace}
        \usepackage{float}
language:
  crossref-fig-title: "Figura"
  crossref-tbl-title: "Tabla"
  crossref-eq-prefix: "Ecuación"
  crossref-fig-prefix: "figura"
  crossref-tbl-prefix: "tabla"
  toc-title: "Índice de contenidos"
  # references-title: "Referencias"
  appendix-title: "Apéndices"
  section-title-append: false
